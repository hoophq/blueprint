<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="color-scheme" content="dark">
<title>blueprint report</title>
<style>
  /* blueprint report — dark, single file, no external resources:
     font-family names only, everything inline. */
  :root { color-scheme: dark; }
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  body {
    min-height: 100vh;
    background: #0c0c0c;
    color: #F7F7F7;
    font-family: Inter, system-ui, -apple-system, sans-serif;
    font-size: 14px;
    line-height: 1.45;
  }
  [hidden] { display: none !important; }

  .rr-page {
    max-width: 1080px;
    margin: 0 auto;
    padding: 40px 32px 64px;
  }

  /* ── Header ── */
  .rr-head { padding-bottom: 18px; border-bottom: 1px solid rgba(247, 247, 247, 0.07); }
  .rr-head-row { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
  .rr-brand { display: flex; align-items: center; gap: 8px; }
  .rr-brand-name {
    font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 13px;
    font-weight: 600;
    color: rgba(247, 247, 247, 0.75);
  }
  .rr-brand-ver {
    font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 11px;
    color: rgba(247, 247, 247, 0.35);
    background: rgba(247, 247, 247, 0.06);
    border: 1px solid rgba(247, 247, 247, 0.1);
    border-radius: 5px;
    padding: 2px 7px;
  }
  .rr-gen {
    margin-left: auto;
    font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 11.5px;
    color: rgba(247, 247, 247, 0.35);
  }
  .rr-meta-row { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 14px; }
  .rr-meta-chip {
    font-size: 12px;
    font-weight: 500;
    color: rgba(247, 247, 247, 0.55);
    background: rgba(247, 247, 247, 0.05);
    border: 1px solid rgba(247, 247, 247, 0.1);
    border-radius: 999px;
    padding: 5px 13px;
  }
  .rr-meta-chip-ok {
    color: #7fd1a8;
    border-color: rgba(79, 180, 119, 0.3);
    background: rgba(79, 180, 119, 0.08);
  }

  /* ── Failures banner (honesty ledger) ── */
  .banner {
    margin: 20px 0 0;
    background: rgba(230, 162, 60, 0.07);
    border: 1px solid rgba(230, 162, 60, 0.25);
    border-left: 3px solid #e6a23c;
    border-radius: 10px;
    padding: 11px 16px;
  }
  .banner summary { cursor: pointer; font-weight: 600; font-size: 13.5px; color: #F7F7F7; }
  .banner summary .banner-icon { margin-right: 6px; color: #e6a23c; }
  .banner summary .banner-hint { font-weight: 400; color: rgba(247, 247, 247, 0.45); font-size: 12px; margin-left: 8px; }
  .banner ul { margin: 12px 0 4px; padding-left: 22px; }
  .banner li {
    margin: 6px 0;
    font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 12px;
    color: rgba(247, 247, 247, 0.7);
  }
  .banner li .failure-error { color: rgba(247, 247, 247, 0.45); }

  /* ── Stat strip + attribution bar ── */
  .rr-kpis { display: grid; grid-template-columns: repeat(6, 1fr); gap: 0; }
  .rr-kpi { padding: 0 18px; border-right: 1px solid rgba(247, 247, 247, 0.07); }
  .rr-kpi:first-child { padding-left: 0; }
  .rr-kpi:last-child { border-right: none; padding-right: 0; }
  .rr-kpi-label { font-size: 11.5px; font-weight: 500; color: rgba(247, 247, 247, 0.42); }
  .rr-kpi-num {
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #F7F7F7;
    line-height: 1;
    margin-top: 9px;
  }
  .rr-kpi-denom { font-size: 15px; font-weight: 500; color: rgba(247, 247, 247, 0.35); margin-left: 2px; }
  .rr-kpi-sub { font-size: 11.5px; color: rgba(247, 247, 247, 0.34); margin-top: 7px; }
  .rr-kpi-sub-ok { color: #7fd1a8; }
  .rr-kpi-sub-bad { color: #f08a8e; }

  .rr-attr-bar {
    display: flex;
    gap: 2px;
    height: 8px;
    margin-top: 20px;
    border-radius: 4px;
    overflow: hidden;
  }
  .rr-attr-seg { cursor: pointer; transition: opacity 0.15s; }
  .rr-attr-legend { display: flex; flex-wrap: wrap; gap: 6px 18px; margin-top: 10px; }
  .rr-legend-item {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    background: none;
    border: none;
    padding: 2px 0;
    font-family: inherit;
    font-size: 12px;
    font-weight: 500;
    color: rgba(247, 247, 247, 0.6);
    cursor: pointer;
    transition: opacity 0.15s, color 0.15s;
  }
  .rr-legend-item:hover { color: #F7F7F7; }
  .rr-legend-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .rr-legend-count {
    font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 11px;
    color: rgba(247, 247, 247, 0.4);
  }

  /* ── Section ── */
  .rr-section { padding: 24px 0; border-bottom: 1px solid rgba(247, 247, 247, 0.07); }
  .rr-section:last-child { border-bottom: none; padding-bottom: 0; }
  .rr-section-head {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }
  .rr-section-title { font-size: 16px; font-weight: 700; letter-spacing: -0.01em; color: #F7F7F7; margin: 0; }
  .rr-section-sub { font-size: 12px; color: rgba(247, 247, 247, 0.38); }

  /* shared bar */
  .rr-bar-wrap { height: 6px; background: rgba(247, 247, 247, 0.06); border-radius: 3px; overflow: hidden; }
  .rr-bar { height: 100%; background: rgba(247, 247, 247, 0.3); border-radius: 3px; }

  /* ── Engines rows ── */
  .rr-eng-table { display: flex; flex-direction: column; }
  .rr-eng-row {
    display: grid;
    grid-template-columns: 210px 1fr 120px 48px 90px;
    align-items: center;
    gap: 16px;
    padding: 7px 0;
    border-bottom: 1px solid rgba(247, 247, 247, 0.05);
  }
  .rr-eng-row:last-child { border-bottom: none; }
  .rr-eng-entity { display: flex; align-items: center; gap: 8px; min-width: 0; }
  .rr-eng-dot { width: 8px; height: 8px; border-radius: 2px; flex-shrink: 0; }
  .rr-eng-name {
    font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 12px;
    font-weight: 500;
    color: rgba(247, 247, 247, 0.82);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .rr-eng-family { font-size: 11px; color: rgba(247, 247, 247, 0.34); }
  .rr-eng-total {
    font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 13px;
    font-weight: 500;
    color: rgba(247, 247, 247, 0.75);
    text-align: right;
  }
  .rr-eng-regions {
    font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 11.5px;
    color: rgba(247, 247, 247, 0.38);
    text-align: right;
  }

  /* ── Inventory controls + table ── */
  .controls { display: flex; flex-wrap: wrap; align-items: center; gap: 10px; margin: 0 0 12px; }
  .controls input[type="search"] {
    flex: 1 1 240px;
    max-width: 420px;
    padding: 8px 14px;
    font: inherit;
    font-size: 13px;
    color: #F7F7F7;
    background: rgba(247, 247, 247, 0.05);
    border: 1px solid rgba(247, 247, 247, 0.1);
    border-radius: 8px;
  }
  .controls input[type="search"]::placeholder { color: rgba(247, 247, 247, 0.35); }
  .controls label {
    color: rgba(247, 247, 247, 0.45);
    font-size: 12.5px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .controls select {
    padding: 8px 10px;
    font: inherit;
    font-size: 12.5px;
    color: #F7F7F7;
    background: rgba(247, 247, 247, 0.05);
    border: 1px solid rgba(247, 247, 247, 0.1);
    border-radius: 8px;
  }
  .controls input[type="search"]:focus,
  .controls select:focus,
  .th-btn:focus-visible,
  .rr-legend-item:focus-visible {
    outline: 2px solid rgba(247, 247, 247, 0.6);
    outline-offset: 1px;
  }

  .table-wrap {
    background: rgba(247, 247, 247, 0.02);
    border: 1px solid rgba(247, 247, 247, 0.08);
    border-radius: 10px;
    overflow-x: auto;
  }
  table { width: 100%; border-collapse: collapse; }
  thead th {
    text-align: left;
    padding: 0;
    border-bottom: 1px solid rgba(247, 247, 247, 0.1);
    white-space: nowrap;
  }
  .th-btn {
    display: flex;
    align-items: center;
    gap: 5px;
    width: 100%;
    padding: 9px 10px;
    background: none;
    border: none;
    font-family: inherit;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: rgba(247, 247, 247, 0.45);
    cursor: pointer;
  }
  thead th.num .th-btn { justify-content: flex-end; }
  .th-btn:hover { color: #F7F7F7; }
  .th-btn .dir { font-size: 9px; color: #F7F7F7; min-width: 10px; }
  tbody td {
    padding: 6px 9px;
    border-bottom: 1px solid rgba(247, 247, 247, 0.05);
    font-size: 13px;
    color: rgba(247, 247, 247, 0.75);
    white-space: nowrap;
  }
  tbody td .sub { display: block; margin-top: 1px; }
  tbody tr:last-child td { border-bottom: none; }
  tbody tr:hover td { background: rgba(247, 247, 247, 0.03); }
  tbody tr.group-row td {
    background: rgba(247, 247, 247, 0.045);
    font-weight: 600;
    font-size: 12px;
    color: #F7F7F7;
    padding: 8px 10px;
  }
  tbody tr.group-row:hover td { background: rgba(247, 247, 247, 0.045); }
  .group-count { color: rgba(247, 247, 247, 0.45); font-weight: 400; margin-left: 8px; }
  td.mono, .mono {
    font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 12px;
  }
  td.mono { color: rgba(247, 247, 247, 0.8); }
  td.num { text-align: right; font-variant-numeric: tabular-nums; }
  .sub { color: rgba(247, 247, 247, 0.4); font-size: 11px; }
  .dim { color: rgba(247, 247, 247, 0.3); }
  tr.no-match td { padding: 20px 12px; text-align: center; }
  .tier-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    margin-right: 8px;
    vertical-align: 0;
  }

  /* ── Value tags (environment, status) ── */
  .tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    font-weight: 500;
    line-height: 1;
    padding: 3px 9px;
    border-radius: 999px;
    border: 1px solid rgba(247, 247, 247, 0.12);
    background: rgba(247, 247, 247, 0.05);
    color: rgba(247, 247, 247, 0.65);
    white-space: nowrap;
  }
  .tag-dot { width: 5px; height: 5px; border-radius: 50%; background: currentColor; flex-shrink: 0; }
  .tag-green  { color: #7fd1a8; border-color: rgba(79, 180, 119, 0.3);  background: rgba(79, 180, 119, 0.08); }
  .tag-amber  { color: #eab765; border-color: rgba(230, 162, 60, 0.3);  background: rgba(230, 162, 60, 0.08); }
  .tag-red    { color: #f08a8e; border-color: rgba(229, 72, 77, 0.35);  background: rgba(229, 72, 77, 0.09); }
  .tag-blue   { color: #8ab8fa; border-color: rgba(90, 156, 248, 0.3);  background: rgba(90, 156, 248, 0.08); }
  .tag-purple { color: #ac9ff8; border-color: rgba(139, 124, 246, 0.3); background: rgba(139, 124, 246, 0.08); }
  .tag-cyan   { color: #7cd0f8; border-color: rgba(56, 189, 248, 0.3);  background: rgba(56, 189, 248, 0.08); }
  .tag-pink   { color: #f7a1cb; border-color: rgba(244, 114, 182, 0.3); background: rgba(244, 114, 182, 0.08); }

  /* ── Empty state ── */
  .empty h2 { margin: 0 0 8px; font-size: 17px; color: #F7F7F7; }
  .empty p { margin: 0 0 8px; color: rgba(247, 247, 247, 0.55); }
  .empty ul { margin: 0; padding-left: 22px; color: rgba(247, 247, 247, 0.55); }
  .empty li { margin: 4px 0; }
  .empty .mono { color: rgba(247, 247, 247, 0.75); font-size: 12.5px; }

  /* ── Footer ── */
  .rr-foot {
    margin-top: 28px;
    text-align: center;
    font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 11.5px;
    color: rgba(247, 247, 247, 0.3);
  }
  .rr-foot a { color: rgba(247, 247, 247, 0.5); text-decoration: none; }
  .rr-foot a:hover { text-decoration: underline; }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .rr-kpis { grid-template-columns: repeat(3, 1fr); gap: 18px 24px; }
    .rr-kpi { border-right: none; padding: 0; }
  }
  @media (max-width: 680px) {
    .rr-eng-row { grid-template-columns: 1fr auto; }
    .rr-eng-family, .rr-eng-row .rr-bar-wrap, .rr-eng-regions { display: none; }
  }
  @media (max-width: 600px) {
    .rr-page { padding: 28px 16px 56px; }
    .rr-kpis { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>

<div class="rr-page">

  <header class="rr-head">
    <div class="rr-head-row">
      <div class="rr-brand">
        <svg width="18" height="18" viewBox="0 0 148 148" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M96.4167 71.4077C99.0238 71.5517 101.631 71.7389 104.238 71.9118L106.6 72.0558C114.055 73.1865 121.677 71.9359 128.38 68.4821C135.083 65.0282 140.525 59.5473 143.931 52.82C147.337 46.0928 148.533 38.4622 147.349 31.0153C146.166 23.5685 142.662 16.685 137.338 11.3455C132.014 6.00604 125.14 2.48279 117.697 1.27765C110.254 0.0725119 102.62 1.24695 95.8826 4.63367C89.1456 8.02038 83.6491 13.4467 80.176 20.1396C76.7029 26.8325 75.4304 34.4507 76.5397 41.909C76.5397 42.73 76.6405 43.551 76.6982 44.372C76.871 46.9791 77.0582 49.6005 77.1879 52.2076C77.5862 56.2358 77.0945 60.3023 75.7475 64.1194C74.7082 66.7342 73.1556 69.1144 71.1816 71.1196C69.1658 73.1255 66.7584 74.6945 64.1094 75.7287C60.2922 77.0757 56.2257 77.5675 52.1976 77.1691C49.5905 77.0395 46.9691 76.8522 44.362 76.6794L41.899 76.5209C34.4419 75.414 26.8257 76.688 20.1348 80.1613C13.4439 83.6347 8.01933 89.1305 4.63351 95.8662C1.24769 102.602 0.0732001 110.234 1.27728 117.676C2.48136 125.118 6.00262 131.99 11.3397 137.315C16.6768 142.639 23.5576 146.144 31.0024 147.33C38.4472 148.516 46.0766 147.324 52.8041 143.922C59.5317 140.52 65.0144 135.082 68.4718 128.383C71.9292 121.684 73.1849 114.065 72.0602 106.61C72.0602 105.818 71.9738 105.04 71.9162 104.248C71.7433 101.641 71.5561 99.0338 71.412 96.4268C71.0353 92.3933 71.5517 88.3263 72.9244 84.515C73.9445 81.8936 75.4939 79.5106 77.476 77.5148C79.4819 75.5453 81.8621 73.9976 84.4761 72.9633C88.2932 71.5717 92.3705 71.0405 96.4167 71.4077Z" fill="#F7F7F7"/>
          <path d="M36.7283 63.0103C51.238 63.0103 63.0005 51.2478 63.0005 36.7381C63.0005 22.2283 51.238 10.4658 36.7283 10.4658C22.2185 10.4658 10.4561 22.2283 10.4561 36.7381C10.4561 51.2478 22.2185 63.0103 36.7283 63.0103Z" fill="#F7F7F7"/>
          <path d="M111.944 138.226C126.454 138.226 138.216 126.464 138.216 111.954C138.216 97.4441 126.454 85.6816 111.944 85.6816C97.4344 85.6816 85.6719 97.4441 85.6719 111.954C85.6719 126.464 97.4344 138.226 111.944 138.226Z" fill="#F7F7F7"/>
        </svg>
        <span class="rr-brand-name">blueprint</span>
        <span class="rr-brand-ver" id="brand-ver"></span>
      </div>
      <span class="rr-gen">generated locally &middot; <span id="gen-at"></span></span>
    </div>
    <div class="rr-meta-row">
      <span class="rr-meta-chip" id="chip-scope"></span>
      <span class="rr-meta-chip">read-only</span>
      <span class="rr-meta-chip rr-meta-chip-ok">computed locally &middot; nothing leaves your machine</span>
    </div>
  </header>

  <section id="failures-banner" class="banner" hidden>
    <details>
      <summary><span class="banner-icon">&#9888;</span><span id="failures-title"></span><span class="banner-hint">expand for details</span></summary>
      <ul id="failures-list"></ul>
    </details>
  </section>

  <section id="empty-state" class="rr-section empty" hidden>
    <h2>No databases found</h2>
    <p>The scan completed but discovered no managed databases. Possible causes:</p>
    <ul>
      <li>The credentials point at the wrong AWS account or profile.</li>
      <li>The scanned regions host no managed databases &mdash; try scanning more regions.</li>
      <li>The role is missing read permissions (for example <span class="mono">rds:DescribeDBInstances</span>, <span class="mono">dynamodb:ListTables</span>, <span class="mono">elasticache:DescribeCacheClusters</span>).</li>
      <li>Databases are self-hosted on EC2 &mdash; blueprint only sees AWS-managed services.</li>
    </ul>
  </section>

  <section class="rr-section" id="stats-section">
    <div class="rr-kpis" id="kpis"></div>
    <div class="rr-attr-bar" id="attr-bar" aria-label="Databases by attribution tier"></div>
    <div class="rr-attr-legend" id="attr-legend"></div>
  </section>

  <section class="rr-section" id="engines-section">
    <div class="rr-section-head">
      <h2 class="rr-section-title">Engines</h2>
      <span class="rr-section-sub" id="engines-sub"></span>
    </div>
    <div class="rr-eng-table" id="engine-rows"></div>
  </section>

  <section class="rr-section" id="table-section">
    <div class="rr-section-head">
      <h2 class="rr-section-title">Inventory</h2>
      <span class="rr-section-sub" id="row-count"></span>
    </div>
    <div class="controls">
      <input id="filter" type="search" placeholder="Filter by name, engine, ARN, or tag" aria-label="Filter databases">
      <label>Group by
        <select id="groupby">
          <option value="none" selected>none</option>
          <option value="service">service</option>
          <option value="engine">engine</option>
          <option value="environment">environment</option>
          <option value="region">region</option>
          <option value="account">account</option>
        </select>
      </label>
    </div>
    <div class="table-wrap">
      <table id="census">
        <thead><tr id="head-row"></tr></thead>
        <tbody id="rows"></tbody>
      </table>
    </div>
  </section>

  <footer class="rr-foot">generated locally by blueprint &mdash; open source: <a href="https://github.com/hoophq/blueprint" target="_blank" rel="noreferrer">github.com/hoophq/blueprint</a> &middot; nothing leaves your machine</footer>

</div>

<script type="application/json" id="blueprint-data">__BLUEPRINT_JSON__</script>
<script>
(function () {
  "use strict";

  var data = JSON.parse(document.getElementById("blueprint-data").textContent);
  var resources = data.resources || [];
  var failures = data.failures || [];

  // Attribution tiers: ownership hygiene computed from owner/environment tags.
  // Ordered as they appear in the stacked attribution bar and its legend.
  var TIERS = [
    { key: "full", label: "Fully attributed", color: "#4fb477", count: 0 },
    { key: "partial", label: "Partially attributed", color: "#e6a23c", count: 0 },
    { key: "untagged", label: "Untagged", color: "#e5484d", count: 0 }
  ];
  var TIER_BY_KEY = {};
  TIERS.forEach(function (t) { TIER_BY_KEY[t.key] = t; });

  // Categorical service palette tuned for the #0c0c0c page.
  var SERVICE_COLORS = {
    rds: "#5a9cf8",
    aurora: "#8b7cf6",
    documentdb: "#4fb477",
    neptune: "#38bdf8",
    dynamodb: "#e6a23c",
    elasticache: "#e5484d",
    redshift: "#f472b6"
  };
  var SERVICE_FALLBACK = "rgba(247,247,247,0.35)";

  function tierOf(r) {
    if (r.owner && r.environment) return "full";
    if (r.owner || r.environment) return "partial";
    return "untagged";
  }

  // Precompute the tier and one lowercase haystack per row for the filter.
  resources.forEach(function (r) {
    r._tier = tierOf(r);
    TIER_BY_KEY[r._tier].count++;
    var hay = [r.name, r.engine, r.engine_version, r.arn, r.service, r.kind,
      r.region, r.account_id, r.environment, r.owner, r.status, r.instance_class];
    if (r.eol) hay.push("eol");
    if (r.tags) {
      Object.keys(r.tags).forEach(function (k) {
        hay.push(k, r.tags[k], k + "=" + r.tags[k]);
      });
    }
    r._hay = hay.filter(Boolean).join("\n").toLowerCase();
  });

  function el(tag, cls, text) {
    var e = document.createElement(tag);
    if (cls) e.className = cls;
    if (text !== undefined && text !== null && text !== "") e.textContent = text;
    return e;
  }

  function plural(n, noun) {
    return n.toLocaleString() + " " + noun + (n === 1 ? "" : "s");
  }

  // ---- Header metadata ------------------------------------------------------
  var gen = new Date(data.generated_at);
  var genEl = document.getElementById("gen-at");
  genEl.textContent = isNaN(gen.getTime())
    ? String(data.generated_at || "")
    : gen.toLocaleString(undefined, { year: "numeric", month: "short", day: "numeric", hour: "2-digit", minute: "2-digit" });
  genEl.title = String(data.generated_at || "");

  var verEl = document.getElementById("brand-ver");
  if (data.version) { verEl.textContent = String(data.version); } else { verEl.hidden = true; }

  var accounts = data.accounts || [];
  var regions = data.regions || [];
  document.getElementById("chip-scope").textContent =
    plural(accounts.length, "account") + " · " + plural(regions.length, "region") + " · " + plural(resources.length, "database");

  // ---- Failures banner (honesty ledger) ------------------------------------
  if (failures.length > 0) {
    document.getElementById("failures-banner").hidden = false;
    document.getElementById("failures-title").textContent =
      "Incomplete coverage — " + failures.length + " scan unit" + (failures.length === 1 ? "" : "s") + " failed";
    var list = document.getElementById("failures-list");
    failures.forEach(function (f) {
      var li = el("li");
      li.appendChild(el("span", "mono", [f.account_id, f.region, f.service].filter(Boolean).join(" / ")));
      li.appendChild(document.createTextNode(" — "));
      li.appendChild(el("span", "failure-error", f.error));
      list.appendChild(li);
    });
  }

  // ---- Empty state ----------------------------------------------------------
  if (resources.length === 0) {
    document.getElementById("empty-state").hidden = false;
    ["stats-section", "engines-section", "table-section"].forEach(function (id) {
      document.getElementById(id).hidden = true;
    });
    return;
  }

  var total = resources.length;

  // Tier filter composes with the free-text filter via AND.
  var activeTier = null;

  // ---- Stat strip -----------------------------------------------------------
  var seen = { engines: {}, accounts: {} };
  var noOwner = 0;
  var eolCount = 0;
  resources.forEach(function (r) {
    if (r.engine) seen.engines[r.engine] = true;
    if (r.account_id) seen.accounts[r.account_id] = true;
    if (!r.owner) noOwner++;
    if (r.eol) eolCount++;
  });

  var kpisEl = document.getElementById("kpis");
  function addStat(label, num, sub, opts) {
    var box = el("div", "rr-kpi");
    box.appendChild(el("div", "rr-kpi-label", label));
    var numEl = el("div", "rr-kpi-num", num);
    if (opts && opts.denom) numEl.appendChild(el("span", "rr-kpi-denom", opts.denom));
    box.appendChild(numEl);
    var subCls = "rr-kpi-sub";
    if (opts && opts.ok) subCls += " rr-kpi-sub-ok";
    if (opts && opts.bad) subCls += " rr-kpi-sub-bad";
    box.appendChild(el("div", subCls, sub));
    kpisEl.appendChild(box);
  }
  addStat("Databases", total.toLocaleString(),
    plural(Object.keys(seen.engines).length, "engine") + " · " + plural(Object.keys(seen.accounts).length, "account"));
  addStat("Attribution score", String(Math.round((100 * TIER_BY_KEY.full.count) / total)),
    "owner + environment tagged", { denom: "/100" });
  addStat("Untagged", TIER_BY_KEY.untagged.count.toLocaleString(), "no owner or environment");
  addStat("Missing owner", noOwner.toLocaleString(), Math.round((100 * noOwner) / total) + "% of all databases");
  addStat("End-of-life", eolCount.toLocaleString(),
    eolCount === 0 ? "no EOL engine versions" : "upstream support ended",
    eolCount === 0 ? { ok: true } : { bad: true });
  addStat("Scan failures", failures.length.toLocaleString(),
    failures.length === 0 ? "every scan unit succeeded" : "see incomplete-coverage details above",
    { ok: failures.length === 0 });

  // ---- Attribution bar + legend ---------------------------------------------
  var barEl = document.getElementById("attr-bar");
  TIERS.forEach(function (t) {
    if (t.count === 0) return;
    var seg = el("div", "rr-attr-seg");
    seg.style.background = t.color;
    seg.style.flex = t.count + " 1 0%";
    seg.title = t.label + " · " + plural(t.count, "database");
    seg.addEventListener("click", function () { setTier(t.key); });
    t._seg = seg;
    barEl.appendChild(seg);
  });

  var legendEl = document.getElementById("attr-legend");
  TIERS.forEach(function (t) {
    var btn = el("button", "rr-legend-item");
    btn.type = "button";
    btn.setAttribute("aria-pressed", "false");
    var dot = el("span", "rr-legend-dot");
    dot.style.background = t.color;
    btn.appendChild(dot);
    btn.appendChild(el("span", "", t.label));
    btn.appendChild(el("span", "rr-legend-count", t.count.toLocaleString()));
    btn.addEventListener("click", function () { setTier(t.key); });
    t._leg = btn;
    legendEl.appendChild(btn);
  });

  function setTier(key) {
    activeTier = activeTier === key ? null : key;
    syncTierUI();
    render();
  }

  function syncTierUI() {
    TIERS.forEach(function (t) {
      var dimmed = activeTier !== null && activeTier !== t.key;
      if (t._seg) t._seg.style.opacity = dimmed ? "0.25" : "1";
      if (t._leg) {
        t._leg.style.opacity = dimmed ? "0.25" : "1";
        t._leg.setAttribute("aria-pressed", activeTier === t.key ? "true" : "false");
      }
    });
  }

  // ---- Engines ----------------------------------------------------------------
  var engineMap = {};
  var engineRows = [];
  var servicesSeen = {};
  var serviceCount = 0;
  resources.forEach(function (r) {
    var key = r.engine || "(unknown)";
    var e = engineMap[key];
    if (!e) {
      e = engineMap[key] = { name: key, service: r.service || "", count: 0, versions: {}, regions: {} };
      engineRows.push(e);
    }
    e.count++;
    if (r.engine_version) e.versions[r.engine_version] = true;
    if (r.region) e.regions[r.region] = true;
    if (r.service && !servicesSeen[r.service]) {
      servicesSeen[r.service] = true;
      serviceCount++;
    }
  });
  engineRows.sort(function (a, b) {
    return b.count - a.count || (a.name < b.name ? -1 : a.name > b.name ? 1 : 0);
  });

  var engRowsEl = document.getElementById("engine-rows");
  var max = 1;
  engineRows.forEach(function (e) { if (e.count > max) max = e.count; });
  var engFrag = document.createDocumentFragment();
  engineRows.forEach(function (e) {
    var row = el("div", "rr-eng-row");
    var entity = el("div", "rr-eng-entity");
    var dot = el("span", "rr-eng-dot");
    dot.style.background = SERVICE_COLORS[e.service] || SERVICE_FALLBACK;
    entity.appendChild(dot);
    entity.appendChild(el("span", "rr-eng-name", e.name));
    row.appendChild(entity);
    var nver = Object.keys(e.versions).length;
    row.appendChild(el("div", "rr-eng-family", nver > 0 ? e.service + " · " + plural(nver, "version") : e.service));
    var barWrap = el("div", "rr-bar-wrap");
    var bar = el("div", "rr-bar");
    bar.style.width = Math.round((e.count / max) * 100) + "%";
    barWrap.appendChild(bar);
    row.appendChild(barWrap);
    row.appendChild(el("div", "rr-eng-total", e.count.toLocaleString()));
    row.appendChild(el("div", "rr-eng-regions", plural(Object.keys(e.regions).length, "region")));
    engFrag.appendChild(row);
  });
  engRowsEl.replaceChildren(engFrag);
  document.getElementById("engines-sub").textContent =
    plural(engineRows.length, "engine") + " · " + plural(serviceCount, "service");

  // ---- Inventory table ----------------------------------------------------
  var COLUMNS = [
    { key: "name", label: "Name" },
    { key: "service", label: "Service" },
    { key: "engine", label: "Engine" },
    { key: "instance_class", label: "Class" },
    { key: "storage_gb", label: "Storage", num: true },
    { key: "region", label: "Region" },
    { key: "account_id", label: "Account" },
    { key: "environment", label: "Environment" },
    { key: "owner", label: "Owner" },
    { key: "status", label: "Status" }
  ];
  var GROUP_FIELD = { service: "service", engine: "engine", environment: "environment", region: "region", account: "account_id" };

  var filterEl = document.getElementById("filter");
  var groupEl = document.getElementById("groupby");
  var countEl = document.getElementById("row-count");
  var tbody = document.getElementById("rows");
  var sortKey = null;
  var sortDir = 1;

  var headRow = document.getElementById("head-row");
  COLUMNS.forEach(function (c) {
    var th = document.createElement("th");
    th.scope = "col";
    if (c.num) th.className = "num";
    var btn = el("button", "th-btn");
    btn.type = "button";
    btn.appendChild(el("span", "", c.label));
    var dir = el("span", "dir");
    btn.appendChild(dir);
    btn.addEventListener("click", function () {
      if (sortKey === c.key) {
        if (sortDir === 1) { sortDir = -1; } else { sortKey = null; sortDir = 1; }
      } else {
        sortKey = c.key;
        sortDir = 1;
      }
      updateSortIndicators();
      render();
    });
    th.appendChild(btn);
    headRow.appendChild(th);
    c._th = th;
    c._dir = dir;
  });

  function updateSortIndicators() {
    COLUMNS.forEach(function (c) {
      var active = c.key === sortKey;
      c._dir.textContent = active ? (sortDir === 1 ? "▲" : "▼") : "";
      c._th.setAttribute("aria-sort", active ? (sortDir === 1 ? "ascending" : "descending") : "none");
    });
  }

  function sortValue(r, key) {
    if (key === "storage_gb") return r.storage_gb || 0;
    return String(r[key] || "").toLowerCase();
  }

  // compareRows orders by the column value; equal engine names are tie-broken
  // by engine_version compared numerically, so "15.4" sorts after "9.6".
  function compareRows(a, b, key) {
    var av = sortValue(a, key);
    var bv = sortValue(b, key);
    if (typeof av === "number") return av - bv;
    if (av !== bv) return av < bv ? -1 : 1;
    if (key === "engine") {
      return String(a.engine_version || "").localeCompare(String(b.engine_version || ""), undefined, { numeric: true });
    }
    return 0;
  }

  function cellOrDash(v, cls) {
    var c = el("td", cls);
    if (v) {
      c.textContent = v;
    } else {
      c.textContent = "—";
      c.className = (cls ? cls + " " : "") + "dim";
    }
    return c;
  }

  // Environment tags are colored by normalized bucket so "prod", "prd" and
  // "production" read as the same thing; unrecognized values stay neutral.
  var ENV_BUCKETS = [
    { cls: "tag-purple", re: /^(prod|prd|production|live)$/ },
    { cls: "tag-cyan", re: /^(stag(e|ing)?|stg|pre-?prod|uat)$/ },
    { cls: "tag-blue", re: /^(dev|development)$/ },
    { cls: "tag-pink", re: /^(test(ing)?|qa|sandbox|sbx)$/ }
  ];
  function envClass(v) {
    v = v.toLowerCase();
    for (var i = 0; i < ENV_BUCKETS.length; i++) {
      if (ENV_BUCKETS[i].re.test(v)) return ENV_BUCKETS[i].cls;
    }
    return "";
  }

  // Status tags map AWS lifecycle states to a traffic light: healthy green,
  // gone-wrong red, intentionally-off amber, in-transition blue.
  function statusClass(v) {
    v = v.toLowerCase();
    if (/^(available|active|running|healthy)$/.test(v)) return "tag-green";
    if (/fail|error|incompatible|inaccessible|storage-full|delet/.test(v)) return "tag-red";
    if (/stopp|paus|inactive/.test(v)) return "tag-amber";
    if (/creat|modif|backing|start|reboot|upgrad|updat|maint|resiz|renam|migrat|snapshot|configur/.test(v)) return "tag-blue";
    return "";
  }

  function tagCell(v, cls, withDot) {
    if (!v) return cellOrDash("", "");
    var td = document.createElement("td");
    var tag = el("span", "tag" + (cls ? " " + cls : ""));
    if (withDot) tag.appendChild(el("span", "tag-dot"));
    tag.appendChild(el("span", "", v));
    td.appendChild(tag);
    return td;
  }

  function buildRow(r) {
    var tr = document.createElement("tr");

    var name = el("td", "mono");
    var tierDot = el("span", "tier-dot");
    tierDot.style.background = TIER_BY_KEY[r._tier].color;
    tierDot.title = TIER_BY_KEY[r._tier].label;
    name.appendChild(tierDot);
    name.appendChild(document.createTextNode(r.name || ""));
    if (r.arn) name.title = r.arn;
    tr.appendChild(name);

    var svc = el("td", "", "");
    svc.appendChild(el("span", "", r.service || ""));
    if (r.kind) {
      svc.appendChild(document.createTextNode(" "));
      svc.appendChild(el("span", "sub", r.kind));
    }
    tr.appendChild(svc);

    var eng = el("td", "", "");
    eng.appendChild(el("span", "", r.engine || ""));
    if (r.engine_version) {
      eng.appendChild(document.createTextNode(" "));
      eng.appendChild(el("span", "sub", r.engine_version));
    }
    if (r.eol) {
      eng.appendChild(document.createTextNode(" "));
      var eol = el("span", "tag tag-red", "EOL");
      if (r.eol_date) eol.title = "upstream end of life: " + r.eol_date;
      eng.appendChild(eol);
    }
    tr.appendChild(eng);

    tr.appendChild(cellOrDash(r.instance_class, "mono"));

    tr.appendChild(cellOrDash(r.storage_gb > 0 ? r.storage_gb.toLocaleString() + " GB" : "", "num"));

    tr.appendChild(cellOrDash(r.region, "mono"));
    tr.appendChild(cellOrDash(r.account_id, "mono"));
    tr.appendChild(tagCell(r.environment, envClass(r.environment || ""), false));
    tr.appendChild(cellOrDash(r.owner, ""));
    tr.appendChild(tagCell(r.status, statusClass(r.status || ""), true));
    return tr;
  }

  function currentRows() {
    var q = filterEl.value.trim().toLowerCase();
    var terms = q ? q.split(/\s+/) : null;
    var rows = resources.filter(function (r) {
      if (activeTier && r._tier !== activeTier) return false;
      if (terms) {
        for (var i = 0; i < terms.length; i++) {
          if (r._hay.indexOf(terms[i]) === -1) return false;
        }
      }
      return true;
    });
    if (sortKey) {
      rows.sort(function (a, b) {
        return sortDir * compareRows(a, b, sortKey);
      });
    }
    return rows;
  }

  function render() {
    var rows = currentRows();
    var frag = document.createDocumentFragment();
    var groupBy = groupEl.value;

    if (rows.length === 0) {
      var tr = el("tr", "no-match");
      var td = el("td", "dim", "No databases match the current filters.");
      td.colSpan = COLUMNS.length;
      tr.appendChild(td);
      frag.appendChild(tr);
    } else if (groupBy !== "none" && GROUP_FIELD[groupBy]) {
      var field = GROUP_FIELD[groupBy];
      var groups = {};
      var order = [];
      rows.forEach(function (r) {
        var v = String(r[field] || "");
        if (!Object.prototype.hasOwnProperty.call(groups, v)) {
          groups[v] = [];
          order.push(v);
        }
        groups[v].push(r);
      });
      order.sort(function (a, b) {
        if (a === "") return 1;
        if (b === "") return -1;
        return groups[b].length - groups[a].length || (a < b ? -1 : a > b ? 1 : 0);
      });
      order.forEach(function (v) {
        var gtr = el("tr", "group-row");
        var gtd = document.createElement("td");
        gtd.colSpan = COLUMNS.length;
        gtd.appendChild(el("span", "group-name", v || (groupBy === "environment" ? "no environment tag" : "(none)")));
        gtd.appendChild(el("span", "group-count", groups[v].length.toLocaleString()));
        gtr.appendChild(gtd);
        frag.appendChild(gtr);
        groups[v].forEach(function (r) { frag.appendChild(buildRow(r)); });
      });
    } else {
      rows.forEach(function (r) { frag.appendChild(buildRow(r)); });
    }

    tbody.replaceChildren(frag);
    countEl.textContent = rows.length.toLocaleString() + " of " + total.toLocaleString() + " databases";
  }

  var debounceTimer = null;
  filterEl.addEventListener("input", function () {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(render, 150);
  });
  groupEl.addEventListener("change", render);

  syncTierUI();
  updateSortIndicators();
  render();
})();
</script>
</body>
</html>
