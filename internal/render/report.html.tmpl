<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="color-scheme" content="dark">
<title>blueprint report</title>
<style>
  /* blueprint report — dark-first hoop.dev brand shell. Single file, no
     external resources: font-family names only, everything inline. */
  :root { color-scheme: dark; }
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  body {
    min-height: 100vh;
    background: #0c0c0c;
    color: #F7F7F7;
    font-family: Inter, system-ui, -apple-system, sans-serif;
    font-size: 14px;
    line-height: 1.45;
    position: relative;
  }
  [hidden] { display: none !important; }

  /* ── Animated background grid ── */
  .hoop-bg-grid {
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(247, 247, 247, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(247, 247, 247, 0.04) 1px, transparent 1px);
    background-size: 48px 48px;
    -webkit-mask-image: radial-gradient(ellipse at 50% 0%, black 0%, transparent 75%);
    mask-image: radial-gradient(ellipse at 50% 0%, black 0%, transparent 75%);
    animation: hoopGridShift 24s linear infinite;
    pointer-events: none;
  }
  @keyframes hoopGridShift {
    0%   { background-position: 0 0, 0 0; }
    100% { background-position: 48px 48px, 48px 48px; }
  }

  /* The prototype uses 1000px; the census inventory carries 10 columns, so
     the page runs slightly wider to keep attribution columns on screen. */
  .rr-page {
    position: relative;
    max-width: 1140px;
    margin: 0 auto;
    padding: 56px 40px 100px;
  }

  /* ── Top brand ── */
  .rr-top {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 32px;
  }
  .rr-top-logo {
    font-size: 24px;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: #F7F7F7;
  }

  /* ── Generated-report window ── */
  .rr-window {
    background: rgba(247, 247, 247, 0.03);
    border: 1px solid rgba(247, 247, 247, 0.1);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.55);
  }
  .rr-window-bar {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 13px 18px;
    border-bottom: 1px solid rgba(247, 247, 247, 0.07);
    background: rgba(247, 247, 247, 0.03);
  }
  .rr-dots { display: flex; gap: 6px; }
  .rr-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(247, 247, 247, 0.12);
  }
  .rr-window-name {
    margin-left: 4px;
    font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 12px;
    color: rgba(247, 247, 247, 0.4);
  }
  .rr-window-meta {
    margin-left: auto;
    font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 11.5px;
    color: rgba(247, 247, 247, 0.3);
  }
  .rr-body { padding: 32px; }

  /* ── Headline + run metadata ── */
  .rr-headline {
    padding-bottom: 28px;
    border-bottom: 1px solid rgba(247, 247, 247, 0.07);
  }
  .rr-brand {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 14px;
  }
  .rr-brand-name {
    font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 13px;
    font-weight: 600;
    color: rgba(247, 247, 247, 0.75);
  }
  .rr-brand-ver {
    font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 11px;
    color: rgba(247, 247, 247, 0.35);
    background: rgba(247, 247, 247, 0.06);
    border: 1px solid rgba(247, 247, 247, 0.1);
    border-radius: 5px;
    padding: 2px 7px;
  }
  .rr-title {
    font-size: clamp(26px, 3.5vw, 34px);
    font-weight: 800;
    letter-spacing: -0.025em;
    color: #F7F7F7;
    margin: 0 0 16px;
    line-height: 1.1;
  }
  .rr-pitch {
    font-size: 15px;
    line-height: 1.6;
    color: rgba(247, 247, 247, 0.55);
    margin: 0 0 16px;
    max-width: 640px;
  }
  .rr-pitch-link {
    color: #F7F7F7;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
  }
  .rr-pitch-link:hover { text-decoration: underline; }
  .rr-meta-row { display: flex; flex-wrap: wrap; gap: 8px; }
  .rr-meta-chip {
    font-size: 12px;
    font-weight: 500;
    color: rgba(247, 247, 247, 0.55);
    background: rgba(247, 247, 247, 0.05);
    border: 1px solid rgba(247, 247, 247, 0.1);
    border-radius: 999px;
    padding: 5px 13px;
  }
  .rr-meta-chip-ok {
    color: #7fd1a8;
    border-color: rgba(79, 180, 119, 0.3);
    background: rgba(79, 180, 119, 0.08);
  }

  /* ── Failures banner (honesty ledger) ── */
  .banner {
    margin: 24px 0 0;
    background: rgba(230, 162, 60, 0.07);
    border: 1px solid rgba(230, 162, 60, 0.25);
    border-left: 3px solid #e6a23c;
    border-radius: 10px;
    padding: 13px 18px;
  }
  .banner summary { cursor: pointer; font-weight: 600; font-size: 13.5px; color: #F7F7F7; }
  .banner summary .banner-icon { margin-right: 6px; color: #e6a23c; }
  .banner summary .banner-hint { font-weight: 400; color: rgba(247, 247, 247, 0.45); font-size: 12px; margin-left: 8px; }
  .banner ul { margin: 12px 0 4px; padding-left: 22px; }
  .banner li {
    margin: 6px 0;
    font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 12px;
    color: rgba(247, 247, 247, 0.7);
  }
  .banner li .failure-error { color: rgba(247, 247, 247, 0.45); }

  /* ── Summary: donut + score + breakdown ── */
  .rr-summary {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    align-items: center;
    padding: 32px 0;
    border-bottom: 1px solid rgba(247, 247, 247, 0.07);
  }
  .rr-donut-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
  }
  .rr-donut { position: relative; width: 200px; height: 200px; }
  .rr-donut svg { width: 100%; height: 100%; transform: rotate(-90deg); }
  .rr-donut-center {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2px;
    pointer-events: none;
  }
  .rr-donut-big {
    font-size: 52px;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #F7F7F7;
    line-height: 1;
  }
  .rr-donut-cap { font-size: 12px; font-weight: 500; color: rgba(247, 247, 247, 0.4); }
  .rr-donut-label { font-size: 12px; color: rgba(247, 247, 247, 0.35); }
  .rr-summary-right { display: flex; flex-direction: column; gap: 12px; }
  .rr-score {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 18px 24px;
    background: rgba(247, 247, 247, 0.05);
    border: 1px solid rgba(247, 247, 247, 0.1);
    border-radius: 10px;
  }
  .rr-score-num {
    font-size: 44px;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #F7F7F7;
    line-height: 1;
  }
  .rr-score-denom { font-size: 20px; font-weight: 500; color: rgba(247, 247, 247, 0.35); }
  .rr-score-label {
    margin-left: auto;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(247, 247, 247, 0.55);
  }
  .rr-breakdown { display: flex; flex-direction: column; }
  .rr-bd-row {
    display: grid;
    grid-template-columns: 4px 1fr auto auto;
    align-items: center;
    gap: 16px;
    width: 100%;
    background: none;
    border: none;
    border-radius: 8px;
    padding: 12px 12px 12px 0;
    font: inherit;
    color: inherit;
    text-align: left;
    cursor: pointer;
    transition: background 0.15s;
  }
  .rr-bd-row:hover { background: rgba(247, 247, 247, 0.04); }
  .rr-bd-row-active { background: rgba(247, 247, 247, 0.07); }
  .rr-bd-accent { width: 4px; align-self: stretch; min-height: 26px; border-radius: 2px; }
  .rr-bd-label { font-size: 14px; font-weight: 500; color: rgba(247, 247, 247, 0.88); padding-left: 14px; }
  .rr-bd-note {
    font-size: 11px;
    color: rgba(247, 247, 247, 0.38);
    font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    padding-left: 14px;
    margin-top: 2px;
  }
  .rr-bd-sess {
    font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 12px;
    color: rgba(247, 247, 247, 0.45);
  }
  .rr-bd-pct {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #F7F7F7;
    min-width: 52px;
    text-align: right;
  }

  /* ── KPI row ── */
  .rr-kpis {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    padding: 24px 0;
    border-bottom: 1px solid rgba(247, 247, 247, 0.07);
  }
  .rr-kpi { padding: 0 20px; border-right: 1px solid rgba(247, 247, 247, 0.07); }
  .rr-kpi:first-child { padding-left: 0; }
  .rr-kpi:last-child { border-right: none; }
  .rr-kpi-label { font-size: 11.5px; font-weight: 500; color: rgba(247, 247, 247, 0.42); }
  .rr-kpi-num {
    font-size: 30px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #F7F7F7;
    line-height: 1;
    margin-top: 10px;
  }
  .rr-kpi-sub { font-size: 11.5px; color: rgba(247, 247, 247, 0.34); margin-top: 7px; }
  .rr-kpi-sub-ok { color: #7fd1a8; }

  /* ── Section ── */
  .rr-section { padding: 28px 0; border-bottom: 1px solid rgba(247, 247, 247, 0.07); }
  .rr-section:last-child { border-bottom: none; padding-bottom: 0; }
  .rr-section-head {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 18px;
    flex-wrap: wrap;
  }
  .rr-section-title { font-size: 16px; font-weight: 700; letter-spacing: -0.01em; color: #F7F7F7; margin: 0; }
  .rr-section-sub { font-size: 12px; color: rgba(247, 247, 247, 0.38); }
  .rr-empty { font-size: 13px; color: rgba(247, 247, 247, 0.4); padding: 8px 0; }

  /* shared bar */
  .rr-bar-wrap { height: 6px; background: rgba(247, 247, 247, 0.06); border-radius: 3px; overflow: hidden; }
  .rr-bar { height: 100%; background: rgba(247, 247, 247, 0.3); border-radius: 3px; }

  /* ── Filter pills ── */
  .rr-pii-filters { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 16px; }
  .rr-filter {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: inherit;
    font-size: 12px;
    font-weight: 500;
    color: rgba(247, 247, 247, 0.55);
    background: rgba(247, 247, 247, 0.05);
    border: 1px solid rgba(247, 247, 247, 0.1);
    border-radius: 999px;
    padding: 5px 13px;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }
  .rr-filter:hover { border-color: rgba(247, 247, 247, 0.25); color: #F7F7F7; }
  .rr-filter-active { background: #F7F7F7; border-color: #F7F7F7; color: #0c0c0c; }
  .rr-filter-active:hover { color: #0c0c0c; }
  .rr-filter-count {
    font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 11px;
    opacity: 0.6;
  }

  /* ── Engines rows ── */
  .rr-pii-table { display: flex; flex-direction: column; }
  .rr-eng-row {
    display: grid;
    grid-template-columns: 210px 1fr 120px 48px 90px;
    align-items: center;
    gap: 16px;
    padding: 9px 0;
    border-bottom: 1px solid rgba(247, 247, 247, 0.05);
  }
  .rr-eng-row:last-child { border-bottom: none; }
  .rr-eng-entity { display: flex; align-items: center; gap: 8px; min-width: 0; }
  .rr-eng-dot { width: 8px; height: 8px; border-radius: 2px; flex-shrink: 0; }
  .rr-eng-name {
    font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 12px;
    font-weight: 500;
    color: rgba(247, 247, 247, 0.82);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .rr-eng-family { font-size: 11px; color: rgba(247, 247, 247, 0.34); }
  .rr-eng-total {
    font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 13px;
    font-weight: 500;
    color: rgba(247, 247, 247, 0.75);
    text-align: right;
  }
  .rr-eng-regions {
    font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 11.5px;
    color: rgba(247, 247, 247, 0.38);
    text-align: right;
  }

  /* ── Inventory controls + table ── */
  .controls { display: flex; flex-wrap: wrap; align-items: center; gap: 10px; margin: 0 0 14px; }
  .controls input[type="search"] {
    flex: 1 1 240px;
    max-width: 420px;
    padding: 8px 14px;
    font: inherit;
    font-size: 13px;
    color: #F7F7F7;
    background: rgba(247, 247, 247, 0.05);
    border: 1px solid rgba(247, 247, 247, 0.1);
    border-radius: 8px;
  }
  .controls input[type="search"]::placeholder { color: rgba(247, 247, 247, 0.35); }
  .controls label {
    color: rgba(247, 247, 247, 0.45);
    font-size: 12.5px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .controls select {
    padding: 8px 10px;
    font: inherit;
    font-size: 12.5px;
    color: #F7F7F7;
    background: rgba(247, 247, 247, 0.05);
    border: 1px solid rgba(247, 247, 247, 0.1);
    border-radius: 8px;
  }
  .controls input[type="search"]:focus,
  .controls select:focus,
  .th-btn:focus-visible,
  .rr-bd-row:focus-visible,
  .rr-filter:focus-visible,
  .rr-cta:focus-visible {
    outline: 2px solid rgba(247, 247, 247, 0.6);
    outline-offset: 1px;
  }

  .table-wrap {
    background: rgba(247, 247, 247, 0.02);
    border: 1px solid rgba(247, 247, 247, 0.08);
    border-radius: 10px;
    overflow-x: auto;
  }
  table { width: 100%; border-collapse: collapse; }
  thead th {
    text-align: left;
    padding: 0;
    border-bottom: 1px solid rgba(247, 247, 247, 0.1);
    white-space: nowrap;
  }
  .th-btn {
    display: flex;
    align-items: center;
    gap: 5px;
    width: 100%;
    padding: 10px;
    background: none;
    border: none;
    font-family: inherit;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: rgba(247, 247, 247, 0.45);
    cursor: pointer;
  }
  thead th.num .th-btn { justify-content: flex-end; }
  .th-btn:hover { color: #F7F7F7; }
  .th-btn .dir { font-size: 9px; color: #F7F7F7; min-width: 10px; }
  tbody td {
    padding: 7px 9px;
    border-bottom: 1px solid rgba(247, 247, 247, 0.05);
    font-size: 13px;
    color: rgba(247, 247, 247, 0.75);
    white-space: nowrap;
  }
  tbody td .sub { display: block; margin-top: 1px; }
  tbody tr:last-child td { border-bottom: none; }
  tbody tr:hover td { background: rgba(247, 247, 247, 0.03); }
  tbody tr.group-row td {
    background: rgba(247, 247, 247, 0.045);
    font-weight: 600;
    font-size: 12px;
    color: #F7F7F7;
    padding: 9px 10px;
  }
  tbody tr.group-row:hover td { background: rgba(247, 247, 247, 0.045); }
  .group-count { color: rgba(247, 247, 247, 0.45); font-weight: 400; margin-left: 8px; }
  td.mono, .mono {
    font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 12px;
  }
  td.mono { color: rgba(247, 247, 247, 0.8); }
  td.num { text-align: right; font-variant-numeric: tabular-nums; }
  .sub { color: rgba(247, 247, 247, 0.4); font-size: 11px; }
  .dim { color: rgba(247, 247, 247, 0.3); }
  tr.no-match td { padding: 20px 12px; text-align: center; }
  .tier-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    margin-right: 8px;
    vertical-align: 0;
  }

  /* ── Empty state ── */
  .empty h2 { margin: 0 0 8px; font-size: 17px; color: #F7F7F7; }
  .empty p { margin: 0 0 8px; color: rgba(247, 247, 247, 0.55); }
  .empty ul { margin: 0; padding-left: 22px; color: rgba(247, 247, 247, 0.55); }
  .empty li { margin: 4px 0; }
  .empty .mono { color: rgba(247, 247, 247, 0.75); font-size: 12.5px; }

  /* ── CTA — white call-out to the open source repo ── */
  .rr-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 28px;
    flex-wrap: wrap;
    margin-top: 20px;
    background: #F5F5F3;
    border-radius: 16px;
    padding: 32px 36px;
    text-decoration: none;
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .rr-cta:hover { transform: translateY(-2px); box-shadow: 0 16px 40px rgba(0, 0, 0, 0.35); }
  .rr-cta-text { min-width: 240px; }
  .rr-cta-title { font-size: 18px; font-weight: 800; letter-spacing: -0.01em; color: #111111; margin: 0 0 6px; }
  .rr-cta-body { font-size: 14px; line-height: 1.55; color: #555555; margin: 0; max-width: 460px; }
  .rr-cta-btn {
    flex-shrink: 0;
    font-size: 14px;
    font-weight: 600;
    color: #F7F7F7;
    background: #111111;
    border-radius: 8px;
    padding: 11px 22px;
    white-space: nowrap;
    transition: opacity 0.15s;
  }
  .rr-cta:hover .rr-cta-btn { opacity: 0.9; }

  /* ── Footer ── */
  .rr-foot {
    margin-top: 28px;
    text-align: center;
    font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 11.5px;
    color: rgba(247, 247, 247, 0.3);
  }

  /* ── Responsive ── */
  @media (max-width: 760px) {
    .rr-summary { grid-template-columns: 1fr; }
  }
  @media (max-width: 680px) {
    .rr-eng-row { grid-template-columns: 1fr auto; }
    .rr-eng-family, .rr-eng-row .rr-bar-wrap, .rr-eng-regions { display: none; }
  }
  @media (max-width: 600px) {
    .rr-page { padding: 32px 16px 80px; }
    .rr-body { padding: 22px 18px; }
    .rr-window-meta { display: none; }
    .rr-kpis { grid-template-columns: 1fr; gap: 20px 0; }
    .rr-kpi { padding-left: 0; border-right: none; }
    .rr-cta { padding: 26px 24px; }
  }
</style>
</head>
<body>

<div class="hoop-bg-grid" aria-hidden="true"></div>

<div class="rr-page">

  <div class="rr-top">
    <svg width="40" height="40" viewBox="0 0 148 148" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
